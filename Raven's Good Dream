searchInput.addEventListener("keyup", function(){


let value = searchInput.value.toLowerCase();


let content = document.querySelector(".container").innerText.toLowerCase();



if(value !== "" && content.includes(value)){


searchInput.style.borderColor="#22c55e";


}else{


searchInput.style.borderColor="#555";


}


});



</script>



